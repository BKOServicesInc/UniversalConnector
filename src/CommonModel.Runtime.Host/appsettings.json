{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "CommonModel.Runtime": "Debug"
    }
  },
  "Nats": {
    "Servers": ["nats://localhost:4222"],
    "SubjectPrefix": "cdc",
    "UseJetStream": true
  },
  "GenericConnector": {
    "DescriptorDirectory": "connectors",
    "FailOnDescriptorError": false
  },
  "OntologyCache": {
    "EndpointUrl": "",
    "GraphIri": null,
    "RefreshSubject": "cdc.ontology.refresh",
    "LoadOnStartup": false
  }
}
