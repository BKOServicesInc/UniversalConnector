# ── UniversalConnector — environment variables ────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose.
#   cp .env.example .env
#
# .env is listed in .gitignore — never commit real credentials.

# ── NATS ──────────────────────────────────────────────────────────────────────
# Override only when NATS lives on a different host than the connector.
# Leave commented to use the appsettings.json default (nats://localhost:4222).
# Nats__Servers__0=nats://central-nats-host:4222

# ── AVEVA PI System Explorer (PI Asset Framework) ─────────────────────────────
# These match the placeholders in connectors/aveva-piaf-server1.yaml.
# AF_SYSTEM_NAME must match an entry in PI System Explorer → File → Connections.
# Leave AF_USERNAME / AF_PASSWORD blank for Windows-integrated auth.
AF_SYSTEM_NAME=Aveva-Pi
AF_DATABASE=BKO_LULU_DB
AF_USERNAME=
AF_PASSWORD=

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ordersdb
POSTGRES_USER=connector
POSTGRES_PASSWORD=changeme_postgres

# ── SQL Server ────────────────────────────────────────────────────────────────
# SA password must meet SQL Server complexity requirements:
#   >= 8 chars, uppercase, lowercase, digit, special char
SA_PASSWORD=YourStrong@Password1
SQLSERVER_DB=crmdb
SQLSERVER_USER=connector
SQLSERVER_PASSWORD=YourStrong@Password1

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_DB=assetsdb

# ── Fuseki (optional — only used when started with --profile fuseki) ──────────
FUSEKI_ADMIN_PASSWORD=admin
