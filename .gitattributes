# Default: normalize all text files to LF in the repo
* text=auto eol=lf

# Shell scripts must always be LF (they run inside Linux containers)
*.sh text eol=lf

# Windows-only files can keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no line-ending conversion
*.png binary
*.jpg binary
*.ico binary
*.dll binary
*.pdb binary
*.pptx binary
